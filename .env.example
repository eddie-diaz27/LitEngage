# =============================================================================
# GEMINI API CONFIGURATION
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Model selection (choose one):
# - gemini-2.0-flash-exp (fastest, cheapest - RECOMMENDED for MVP)
# - gemini-1.5-flash-002 (stable version)
# - gemini-2.0-pro-exp (best quality, slower, more expensive)
GEMINI_MODEL=gemini-2.5-flash-exp

# Temperature for creative recommendations (0.0-1.0)
# Higher = more creative/diverse, Lower = more focused/consistent
GEMINI_TEMPERATURE=0.7

# Max tokens for responses
GEMINI_MAX_TOKENS=1024

# =============================================================================
# DEEPTEAM GUARDRAILS CONFIGURATION
# =============================================================================
# DeepTeam can use Gemini as the judge model (no separate API key needed)
# Or use OpenAI if preferred: DEEPTEAM_MODEL=gpt-4o-mini

# Model used for guardrail evaluation
DEEPTEAM_MODEL=gemini-2.0-flash-exp

# Guardrail strictness levels (BLOCK_LOW_AND_ABOVE is strictest)
# Options: BLOCK_NONE, BLOCK_LOW_AND_ABOVE, BLOCK_MEDIUM_AND_ABOVE, BLOCK_HIGH_ONLY
SAFETY_THRESHOLD=BLOCK_LOW_AND_ABOVE

# Enable/disable specific guardrails (true/false)
ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_TOPICAL_GUARD=true
ENABLE_TOXICITY_GUARD=true
ENABLE_PRIVACY_GUARD=true
ENABLE_HALLUCINATION_GUARD=true

# Allowed topics for TopicalGuard (comma-separated)
ALLOWED_TOPICS=books,reading,library,literature,authors,genres,recommendations,stories,writing

# Sample rate for guardrails (0.0-1.0, 1.0 = check every request)
# Reduce to 0.5 or 0.3 if latency is an issue
GUARDRAIL_SAMPLE_RATE=1.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./data/library.db

# SQLAlchemy settings
DB_ECHO=false  # Set to true to log all SQL queries (useful for debugging)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# VECTOR STORE (CHROMADB) CONFIGURATION
# =============================================================================
# ChromaDB persistence directory
CHROMA_PERSIST_DIRECTORY=./data/chroma_books_db

# Embedding model options:
# - sentence-transformers/all-MiniLM-L6-v2 (384 dims, fast, CPU-friendly - RECOMMENDED)
# - sentence-transformers/all-mpnet-base-v2 (768 dims, better quality, slower)
# - gemini-embedding-001 (requires API calls, 768 dims default)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimensions (must match model)
EMBEDDING_DIMENSIONS=384

# ChromaDB collection name
CHROMA_COLLECTION_NAME=school_books

# =============================================================================
# FASTAPI BACKEND CONFIGURATION
# =============================================================================
# Server settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated, for Streamlit access)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501

# API prefix (optional)
API_PREFIX=/api

# Enable API documentation (true for development, false for production)
ENABLE_API_DOCS=true

# =============================================================================
# STREAMLIT FRONTEND CONFIGURATION
# =============================================================================
# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Backend API URL (where Streamlit will call FastAPI)
BACKEND_API_URL=http://localhost:8000

# Streamlit theme (optional)
STREAMLIT_THEME_PRIMARY_COLOR=#1f77b4
STREAMLIT_THEME_BACKGROUND_COLOR=#ffffff

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Secret key for JWT tokens and session management
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_generate_a_random_one

# JWT token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Password hashing algorithm
ALGORITHM=HS256

# =============================================================================
# LANGSMITH OBSERVABILITY (OPTIONAL)
# =============================================================================
# Enable LangSmith tracing for debugging and monitoring
# Sign up at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=library-engagement-agent

# Endpoint for LangSmith
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# RECOMMENDATION ENGINE SETTINGS
# =============================================================================
# Number of books to retrieve from vector store
VECTOR_SEARCH_K=10

# Fetch K for MMR (Maximal Marginal Relevance)
VECTOR_SEARCH_FETCH_K=30

# Lambda multiplier for MMR (0.0 = max diversity, 1.0 = max relevance)
# Recommended: 0.7 (70% relevance, 30% diversity)
VECTOR_SEARCH_LAMBDA=0.7

# Default number of recommendations to show
DEFAULT_RECOMMENDATIONS_COUNT=3

# Minimum rating threshold for recommendations (0.0-5.0)
MIN_RATING_THRESHOLD=3.5

# =============================================================================
# READING LEVEL CONFIGURATION
# =============================================================================
# Reading level mapping (can extend with Lexile levels if available)
# Format: grade_level:reading_level_label
# Example: 1:early-reader,2-3:elementary,4-5:middle-elementary,6-8:middle-school,9-12:high-school

# Default reading level if student grade not specified
DEFAULT_READING_LEVEL=middle-elementary

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty to log to console only)
LOG_FILE=./logs/app.log

# Log format
LOG_FORMAT=json  # Options: json, text

# =============================================================================
# RATE LIMITING & CACHING
# =============================================================================
# Enable rate limiting (requests per minute per student)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=10

# Enable semantic caching (requires Redis in production)
ENABLE_SEMANTIC_CACHE=false
CACHE_TTL_SECONDS=3600  # 1 hour

# Redis connection (if using caching)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# DATASET CONFIGURATION
# =============================================================================
# Path to raw dataset files
RAW_DATA_DIR=./data/raw

# Path to processed dataset files
PROCESSED_DATA_DIR=./data/processed

# Maximum books to load (0 = unlimited, useful for testing with subset)
MAX_BOOKS_TO_LOAD=0

# Enable Open Library enrichment (requires internet connection)
ENABLE_OPEN_LIBRARY_ENRICHMENT=false

# Enable Google Books API enrichment (requires API quota)
ENABLE_GOOGLE_BOOKS_ENRICHMENT=false
GOOGLE_BOOKS_API_KEY=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable specific features
ENABLE_LIBRARIAN_REVIEW=false  # Human-in-the-loop for recommendations
ENABLE_READING_HISTORY_TRACKING=true
ENABLE_FEEDBACK_COLLECTION=true
ENABLE_STUDENT_PROFILES=true

# Enable collaborative filtering (requires interaction data)
ENABLE_COLLABORATIVE_FILTERING=false

# =============================================================================
# DEPLOYMENT SETTINGS (PRODUCTION)
# =============================================================================
# Environment (development, staging, production)
ENVIRONMENT=development

# Enable debug mode (never true in production)
DEBUG=true

# HTTPS redirect (enable in production)
FORCE_HTTPS=false

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Google Cloud settings (for Cloud Run deployment)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# =============================================================================
# COMPLIANCE SETTINGS
# =============================================================================
# COPPA compliance mode (extra restrictions for <13 years old)
COPPA_COMPLIANCE_MODE=true

# FERPA compliance mode (educational records protection)
FERPA_COMPLIANCE_MODE=true

# Anonymize student data before sending to LLM
ANONYMIZE_STUDENT_DATA=true

# Data retention period (in days, 0 = indefinite)
DATA_RETENTION_DAYS=365

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test database (separate from main database)
TEST_DATABASE_URL=sqlite:///./data/test_library.db

# Number of mock students to create for testing
TEST_MOCK_STUDENTS_COUNT=10

# Number of mock books per student for reading history
TEST_MOCK_BOOKS_PER_STUDENT=5
